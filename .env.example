# Telegram
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Database (Railway auto-injects these when services are added)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/polybot
REDIS_URL=redis://localhost:6379/0

# External APIs
FRED_API_KEY=your_fred_api_key  # Free: https://fred.stlouisfed.org/

# App Settings
SCAN_INTERVAL_SEC=30
MIN_PROFIT_PCT=0.005
MIN_LIQUIDITY_USD=1000
MAX_POSITION_USD=5000
DEFAULT_MODE=manual  # manual or semi
