# ─── Polybot VPS Environment Variables ────────────────────────────────────────
# Copy this to deploy/.env and fill in all values before running setup-vps.sh

# PostgreSQL password (used internally by docker-compose)
DB_PASSWORD=polybotSecret2026

# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=832659652

# Telegram webhook — set to your domain after SSL is ready
# Example: https://polyboy.tech/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://polyboy.tech/api/telegram/webhook

# App URL (shown in Telegram messages)
APP_URL=https://polyboy.tech

# Polymarket scanner settings
SCAN_INTERVAL_SEC=60
MIN_PROFIT_PCT=0.005
MIN_LIQUIDITY_USD=1000
MAX_POSITION_USD=5000
DEFAULT_MODE=manual

# FRED API key (optional — for macro data)
FRED_API_KEY=
